import { describe, it, expect, vi } from 'vitest';
import { render, screen, fireEvent } from '@testing-library/react';
import Card from './Card';

describe('Card Component', () => {
  it('renders card with title', () => {
    render(
      <Card title="Test Title">
        <p>Test content</p>
      </Card>
    );
    
    expect(screen.getByText('Test Title')).toBeInTheDocument();
    expect(screen.getByText('Test content')).toBeInTheDocument();
  });

  it('renders tags when provided', () => {
    render(
      <Card title="Test Title" tags={['前后端', '基础']}>
        <p>Test content</p>
      </Card>
    );
    
    expect(screen.getByText('前后端')).toBeInTheDocument();
    expect(screen.getByText('基础')).toBeInTheDocument();
  });

  it('does not render tags section when tags array is empty', () => {
    const { container } = render(
      <Card title="Test Title" tags={[]}>
        <p>Test content</p>
      </Card>
    );
    
    // Check that no tag elements are rendered
    const tags = container.querySelectorAll('.rounded-full');
    expect(tags.length).toBe(0);
  });

  it('renders expand button when onExpand is provided', () => {
    const handleExpand = vi.fn();
    render(
      <Card title="Test Title" onExpand={handleExpand}>
        <p>Test content</p>
      </Card>
    );
    
    const expandButton = screen.getByText('展开阅读');
    expect(expandButton).toBeInTheDocument();
  });

  it('does not render expand button when onExpand is not provided', () => {
    render(
      <Card title="Test Title">
        <p>Test content</p>
      </Card>
    );
    
    expect(screen.queryByText('展开阅读')).not.toBeInTheDocument();
  });

  it('calls onExpand when expand button is clicked', () => {
    const handleExpand = vi.fn();
    render(
      <Card title="Test Title" onExpand={handleExpand}>
        <p>Test content</p>
      </Card>
    );
    
    const expandButton = screen.getByText('展开阅读');
    fireEvent.click(expandButton);
    
    expect(handleExpand).toHaveBeenCalledTimes(1);
  });

  it('applies custom className when provided', () => {
    const { container } = render(
      <Card title="Test Title" className="custom-class">
        <p>Test content</p>
      </Card>
    );
    
    const cardElement = container.firstChild as HTMLElement;
    expect(cardElement.className).toContain('custom-class');
  });

  it('applies rounded corners and semi-transparent background styles', () => {
    const { container } = render(
      <Card title="Test Title">
        <p>Test content</p>
      </Card>
    );
    
    const cardElement = container.firstChild as HTMLElement;
    expect(cardElement.className).toContain('rounded-lg');
    expect(cardElement.className).toContain('bg-gray-800/50');
    expect(cardElement.className).toContain('backdrop-blur-sm');
  });
});
